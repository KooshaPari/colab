{
  "$schema": "https://oxc.rs/schema.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/*.generated.*",
    "**/vendor/**",
    "**/vendors/**",
    "**/llama-cli/**",
    "**/assets/**"
  ],
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "import", "promise", "vitest", "jsdoc"],
  "env": {
    "browser": true,
    "node": true,
    "es2022": true,
    "builtin": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "style": "warn",
    "restriction": "off",
    "perf": "warn",
    "nursery": "off"
  },
  "rules": {
    "typescript/no-explicit-any": "warn",
    "typescript/explicit-function-return-type": "off",
    "typescript/explicit-module-boundary-types": "off",
    "eslint/eqeqeq": "warn",
    "eslint/no-duplicate-imports": "warn",
    "eslint/arrow-body-style": "off",
    "eslint/no-debugger": "error",
    "eslint/no-eval": "error",
    "eslint/no-implied-eval": "error",
    "eslint/no-throw-literal": "warn",
    "eslint/no-useless-escape": "warn",
    "eslint/no-constant-condition": "warn",
    "eslint/no-this-alias": "warn",
    "eslint/no-new": "off",
    "eslint/no-unused-expressions": "off",
    "eslint/no-unused-vars": "warn",
    "eslint/no-shadow": "warn",
    "eslint/no-console": "off",
    "eslint/sort-imports": "off",
    "eslint/func-style": "off",
    "eslint/no-undefined": "off",
    "eslint/max-params": ["warn", 6],
    "eslint/max-lines": "off",
    "eslint/max-lines-per-function": "off",
    "eslint/max-statements": "off",
    "eslint/no-magic-numbers": "off",
    "eslint/id-length": "off",
    "eslint/sort-keys": "off",
    "eslint/no-ternary": "off",
    "eslint/no-inline-comments": "off",
    "eslint/init-declarations": "off",
    "eslint/no-continue": "off",
    "eslint/no-plusplus": "off",
    "eslint/no-negated-condition": "off",
    "eslint/class-methods-use-this": "off",
    "eslint/prefer-destructuring": "off",
    "eslint/no-warning-comments": "off",
    "eslint/sort-vars": "off",
    "eslint/no-empty-function": "off",
    "eslint/require-await": "off",
    "eslint/func-names": "off",
    "eslint/max-classes-per-file": "off",
    "eslint/no-promise-executor-return": "off",
    "eslint/complexity": "off",
    "eslint/max-depth": "off",
    "eslint/max-statements-per-line": "off",
    "eslint/no-restricted-imports": "off",
    "eslint/no-await-in-loop": "off",
    "unicorn/require-post-message-target-origin": "off",
    "unicorn/no-useless-fallback-in-spread": "off",
    "unicorn/no-array-sort": "off",
    "unicorn/no-array-reverse": "off",
    "eslint/preserve-caught-error": "off",
    "eslint/no-unassigned-vars": "off",
    "eslint/no-control-regex": "off",
    "eslint/no-debugger": "warn",
    "typescript/no-this-alias": "off",
    "unicorn/error-message": "error",
    "unicorn/prefer-type-error": "error",
    "unicorn/no-null": "off",
    "unicorn/prefer-global-this": "off",
    "unicorn/no-array-for-each": "off",
    "unicorn/no-typeof-undefined": "off",
    "unicorn/prefer-top-level-await": "off",
    "unicorn/filename-case": "off",
    "unicorn/prevent-abbreviations": "off",
    "unicorn/prefer-add-event-listener": "off",
    "unicorn/no-nested-ternary": "warn",
    "unicorn/consistent-function-scoping": "off",
    "import/no-default-export": "off",
    "import/no-named-as-default": "off",
    "import/no-named-as-default-member": "off",
    "import/no-self-import": "warn",
    "import/no-useless-path-segments": "off",
    "import/no-duplicates": "off",
    "import/no-unassigned-import": "off",
    "import/order": "off",
    "import/group-exports": "off",
    "import/exports-last": "off",
    "import/no-relative-parent-imports": "off",
    "import/no-namespace": "off",
    "import/no-anonymous-default-export": "off",
    "import/unambiguous": "off",
    "import/no-nodejs-modules": "off",
    "import/prefer-default-export": "off",
    "import/max-dependencies": "off",
    "import/no-cycle": "off",
    "import/consistent-type-specifier-style": "off",
    "import/no-named-export": "off",
    "jsdoc/require-jsdoc": "off",
    "promise/always-return": "off",
    "promise/prefer-await-to-then": "off",
    "promise/prefer-await-to-callbacks": "off",
    "promise/avoid-new": "off",
    "promise/no-nesting": "off",
    "oxc/no-async-await": "off",
    "oxc/no-optional-chaining": "off",
    "oxc/no-rest-spread-properties": "off",
    "typescript/no-redundant-type-constituents": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/tsconfig-error": "off",
    "typescript/no-unsafe-assignment": "off",
    "typescript/no-unsafe-member-access": "off",
    "typescript/no-unsafe-call": "off",
    "typescript/no-unsafe-return": "off",
    "typescript/strict-boolean-expressions": "off",
    "typescript/no-floating-promises": "off",
    "typescript/no-confusing-void-expression": "off",
    "typescript/promise-function-async": "off",
    "typescript/no-unnecessary-type-assertion": "off",
    "typescript/no-misused-promises": "off",
    "typescript/await-thenable": "off",
    "typescript/prefer-nullish-coalescing": "off",
    "typescript/prefer-optional-chain": "warn",
    "typescript/ban-ts-comment": "off"
  },
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/__tests__/**"
      ],
      "rules": {
        "eslint/no-magic-numbers": "off",
        "eslint/no-console": "off",
        "typescript/no-explicit-any": "off"
      }
    },
    {
      "files": ["**/*.config.ts", "**/*.config.js", "**/vitest.config.*", "**/electrobun.config.*"],
      "rules": {
        "import/no-default-export": "off",
        "eslint/no-magic-numbers": "off"
      }
    }
  ]
}
