{
  "name": "colab",
  "version": "0.14.10",
  "description": "A hybrid browser + code editor for deep work",
  "keywords": [
    "browser",
    "code",
    "editor",
    "nocode"
  ],
  "homepage": "https://github.com/blackboardsh/colab#readme",
  "bugs": {
    "url": "https://github.com/blackboardsh/colab/issues"
  },
  "license": "MIT",
  "author": "Blackboard Technologies Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackboardsh/colab.git"
  },
  "main": "index.js",
  "scripts": {
    "setup": "bun run scripts/setup-deps.ts",
    "build:dev": "bun setup && electrobun build",
    "dev": "bun setup && electrobun dev",
    "build:canary": "electrobun build --env=canary",
    "build:stable": "electrobun build --env=stable",
    "docs:dev": "cd documentation && bun install && bun start",
    "docs:build": "cd documentation && bun install && bun run build",
    "docs:serve": "cd documentation && bun run serve",
    "build:docs:release": "cd documentation && bun run build",
    "push:canary": "bunx npm version prerelease --preid=canary && git push origin main --tags",
    "push:patch": "bunx npm version prepatch --preid=canary && git push origin main --tags",
    "push:minor": "bunx npm version preminor --preid=canary && git push origin main --tags",
    "push:major": "bunx npm version premajor --preid=canary && git push origin main --tags",
    "push:stable": "bunx npm version patch && git push origin main --tags",
    "test": "vitest run",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint -c .oxlintrc.json --fix .",
    "typecheck": "tsc -p tsconfig.ci.json --noEmit"
  },
  "dependencies": {
    "@webflow/webflow-cli": "^1.1.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electrobun": "1.14.4",
    "esbuild": "^0.25.12",
    "esbuild-monaco-editor-plugin": "^0.1.1",
    "esbuild-plugin-solid": "^0.5.0",
    "goldfishdb": "^0.1.3",
    "mixpanel": "^0.18.0",
    "monaco-editor": "0.52.0",
    "simple-git": "^3.22.0",
    "solid-js": "^1.7.5",
    "tailwindcss": "^3.4.3",
    "webflow-api": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260228.1",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.43.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}
